# Public app URL
NEXT_PUBLIC_SITE_URL=https://coalition.pgpz.org

# Server/runtime
REGION_AWS=us-east-1
PGPZ_AWS_ACCESS_KEY_ID=
PGPZ_AWS_SECRET_ACCESS_KEY=
NEXTAUTH_URL=https://coalition.pgpz.org
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_TABLE=PGPZCoalitionNextAuth

# Email provider (AWS SES via SMTP)
EMAIL_SERVER_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=SMTP_USER
EMAIL_SERVER_PASSWORD=SMTP_PASSWORD
EMAIL_SERVER_SECURE=false
EMAIL_FROM="PGPZ Coalition <no-reply@coalition.pgpz.org>"

# Optional gated content signing
CLOUDFRONT_DOMAIN=assets.example.com
KEY_PAIR_ID=APKAEXAMPLE123456789
PRIVATE_KEY_SECRET='-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----'
