# Public app URL
NEXT_PUBLIC_SITE_URL=https://coalition.pgpz.org

# Server/runtime
REGION_AWS=us-east-1
# AWS SDK clients use the default credential provider chain. Locally, select an
# SSO/profile with AWS_PROFILE rather than storing access keys in this file.
# Shared application table. The legacy variable name is retained for deployment compatibility.
NEXTAUTH_TABLE=PGPZCoalitionNextAuth
BETTER_AUTH_URL=https://coalition.pgpz.org
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_TRUSTED_ORIGINS=https://coalition.pgpz.org
# Required in production. Keep this stable because it signs tracked links and email-only assets.
EMAIL_TRACKING_SECRET=replace-with-a-long-random-string
# During a rotation, set this to the former value for one verification window.
EMAIL_TRACKING_SECRET_PREVIOUS=

# Local/non-AWS email fallback. Production must use EMAIL_TRANSPORT=ses and an
# Amplify SSR Compute role; SMTP credentials are never serialized there.
EMAIL_TRANSPORT=smtp
EMAIL_SERVER_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=SMTP_USER
EMAIL_SERVER_PASSWORD=SMTP_PASSWORD
EMAIL_SERVER_SECURE=false
EMAIL_FROM="PGPZ Coalition <no-reply@coalition.pgpz.org>"

# Optional gated content signing
CLOUDFRONT_DOMAIN=assets.example.com
KEY_PAIR_ID=APKAEXAMPLE123456789
PRIVATE_KEY_SECRET='-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----'

# Optional admin policy-update PDF uploads
POLICY_UPDATE_UPLOAD_BUCKET=pgpz-coalition-content
POLICY_UPDATE_UPLOAD_PREFIX=policy-updates/uploads
