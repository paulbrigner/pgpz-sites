# Public app URL
NEXT_PUBLIC_SITE_URL=https://community.pgpz.org

# Server/runtime
REGION_AWS=us-east-1
PGPZ_AWS_ACCESS_KEY_ID=
PGPZ_AWS_SECRET_ACCESS_KEY=
NEXTAUTH_URL=https://community.pgpz.org
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_TABLE=PGPZCommunityNextAuth

# X social proof verification
X_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com/2
X_API_TIMEOUT_MS=15000
X_PROOF_CHALLENGE_TTL_MINUTES=1440
X_PROOF_RATE_LIMIT_WINDOW_MINUTES=15
X_PROOF_CHALLENGE_RATE_LIMIT=10
X_PROOF_VERIFY_RATE_LIMIT=6
X_PROOF_AUTOVERIFY_WINDOW_MINUTES=1440
X_PROOF_AUTOVERIFY_BATCH_SIZE=25
X_PROOF_AUTOVERIFY_GROUP_SIZE=5
X_PROOF_AUTOVERIFY_MAX_ATTEMPTS=8
SOCIAL_PROOF_AUTOVERIFY_SECRET=
MEMBERSHIP_PROOF_RETENTION_POLICY=valid_if_deleted

# Email provider (AWS SES via SMTP)
EMAIL_SERVER_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=SMTP_USER
EMAIL_SERVER_PASSWORD=SMTP_PASSWORD
EMAIL_SERVER_SECURE=false
EMAIL_FROM="PGPZ Community <no-reply@community.pgpz.org>"

# Optional gated content signing
CLOUDFRONT_DOMAIN=assets.example.com
KEY_PAIR_ID=APKAEXAMPLE123456789
PRIVATE_KEY_SECRET='-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----'

# Optional admin policy-update PDF uploads
POLICY_UPDATE_UPLOAD_BUCKET=pgpz-community-content
POLICY_UPDATE_UPLOAD_PREFIX=policy-updates/uploads
