# Public app URL
NEXT_PUBLIC_SITE_URL=https://community.pgpz.org

# Server/runtime
REGION_AWS=us-east-1
# AWS SDK clients use the default credential provider chain. Locally, select an
# SSO/profile with AWS_PROFILE rather than storing access keys in this file.
# Shared application table. The legacy variable name is retained for deployment compatibility.
NEXTAUTH_TABLE=PGPZCommunityNextAuth
BACKGROUND_JOBS_ENABLED=false
BACKGROUND_JOBS_TABLE=PGPZCommunityBackgroundJobs
BACKGROUND_JOBS_QUEUE_URL=
# Required when background jobs are enabled. Share only with the queue bridge Lambdas.
BACKGROUND_JOBS_INTERNAL_SECRET=replace-with-a-long-random-string
# Live smoke mode fails closed unless its sole recipient is an active admin on this list.
BACKGROUND_JOB_SMOKE_ALLOWLIST=paul@paulbrigner.com,div@accrediv.com
BETTER_AUTH_URL=https://community.pgpz.org
BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_TRUSTED_ORIGINS=https://community.pgpz.org
# Required in production. Keep this stable because it signs tracked links and email-only assets.
EMAIL_TRACKING_SECRET=replace-with-a-long-random-string
# During a rotation, set this to the former value for one verification window.
EMAIL_TRACKING_SECRET_PREVIOUS=

# Read-only X Monitor integration. Credentials are server-only; only the
# feature switch is public. Leave disabled unless the complete credential set
# is configured for this Community host.
NEXT_PUBLIC_XMONITOR_ENABLED=false
XMONITOR_READ_API_BASE_URL=
XMONITOR_READ_CLIENT_ID=pgpz-community
XMONITOR_READ_CLIENT_SECRET=
XMONITOR_READ_TIMEOUT_MS=10000

# X social proof verification
X_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com/2
X_API_TIMEOUT_MS=15000
X_PROOF_CHALLENGE_TTL_MINUTES=1440
X_PROOF_RATE_LIMIT_WINDOW_MINUTES=15
X_PROOF_CHALLENGE_RATE_LIMIT=10
X_PROOF_VERIFY_RATE_LIMIT=6
X_PROOF_AUTOVERIFY_WINDOW_MINUTES=1440
X_PROOF_AUTOVERIFY_BATCH_SIZE=25
X_PROOF_AUTOVERIFY_GROUP_SIZE=5
X_PROOF_AUTOVERIFY_MAX_ATTEMPTS=8
SOCIAL_PROOF_AUTOVERIFY_SECRET=
SOCIAL_PROOF_AUTOVERIFY_SECRET_PREVIOUS=
MEMBERSHIP_PROOF_RETENTION_POLICY=valid_if_deleted

# Local/non-AWS email fallback. Production must use EMAIL_TRANSPORT=ses and an
# Amplify SSR Compute role; SMTP credentials are never serialized there.
EMAIL_TRANSPORT=smtp
EMAIL_SERVER_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=SMTP_USER
EMAIL_SERVER_PASSWORD=SMTP_PASSWORD
EMAIL_SERVER_SECURE=false
EMAIL_FROM="PGPZ Community <no-reply@community.pgpz.org>"

# Optional gated content signing
CLOUDFRONT_DOMAIN=assets.example.com
KEY_PAIR_ID=APKAEXAMPLE123456789
PRIVATE_KEY_SECRET='-----BEGIN RSA PRIVATE KEY-----\nREPLACE_WITH_YOUR_PRIVATE_KEY\n-----END RSA PRIVATE KEY-----'

# Optional admin policy-update PDF uploads
POLICY_UPDATE_UPLOAD_BUCKET=pgpz-community-content
POLICY_UPDATE_UPLOAD_PREFIX=policy-updates/uploads
