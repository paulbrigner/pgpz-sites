# Public, client-safe identity
NEXT_PUBLIC_SITE_URL=https://reference.pgpz.org

# Required deployment safety controls
REFERENCE_DEPLOYMENT_MODE=demo
EMAIL_DELIVERY_MODE=disabled

# Optional isolated server configuration. Never reuse a branded app's table,
# credentials, bucket, partition, auth secret, or sender.
REGION_AWS=us-east-1
DYNAMODB_TABLE=PGPZReference
ZEC_SHELF_PARTITION_KEY=REFERENCE#ZEC_SHELF
BETTER_AUTH_URL=https://reference.pgpz.org
BETTER_AUTH_TRUSTED_ORIGINS=https://reference.pgpz.org
BETTER_AUTH_SECRET=replace-with-a-reference-only-secret-at-least-32-characters
EMAIL_FROM=PGPZ Reference <reference@pgpz.org>
