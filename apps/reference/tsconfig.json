{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "@pgpz/core": ["../../packages/core/src/index.ts"],
      "@pgpz/core/server": ["../../packages/core/src/server/index.ts"],
      "@pgpz/ui": ["../../packages/ui/src/index.ts"],
      "@pgpz/zec-shelf": ["../../packages/zec-shelf/src/index.ts"],
      "@pgpz/zec-shelf/client": ["../../packages/zec-shelf/src/client/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "vitest.config.ts"]
}
